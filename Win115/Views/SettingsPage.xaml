<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Win115.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:cvt="using:Win115.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Win115.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:vm="using:Win115.ViewModels"
    Margin="10,10,10,10"
    mc:Ignorable="d">
    <Page.Resources>
        <animations:ImplicitAnimationSet x:Name="ShowTransitions">
            <animations:OffsetAnimation
                EasingMode="EaseOut"
                From="0,24,0"
                To="0"
                Duration="0:0:0.4" />
            <animations:OpacityAnimation
                EasingMode="EaseOut"
                From="0"
                To="1"
                Duration="0:0:0.2" />
        </animations:ImplicitAnimationSet>
        <animations:ImplicitAnimationSet x:Name="HideTransitions">
            <animations:OffsetAnimation
                EasingMode="EaseOut"
                From="0"
                To="0,24,0"
                Duration="0:0:0.3" />
            <animations:OpacityAnimation
                EasingMode="EaseOut"
                From="1"
                To="0"
                Duration="0:0:0.2" />
        </animations:ImplicitAnimationSet>

    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <controls:Segmented
            x:Name="segmentedControl"
            HorizontalAlignment="Center"
            SelectedIndex="0"
            SelectionMode="Single">
            <!--<controls:SegmentedItem
                MinWidth="180"
                Content="常规设置"
                Tag="system" />
            <controls:SegmentedItem
                MinWidth="180"
                Content="视频播放器设置"
                Tag="player" />
            <controls:SegmentedItem
                MinWidth="180"
                Content="云下载设置"
                Tag="cloudDownload" />-->
            <controls:SegmentedItem
                MinWidth="180"
                Content="下载设置"
                Tag="download" />
            <!--<controls:SegmentedItem
                MinWidth="180"
                Content="上传设置"
                Tag="upload" />-->
        </controls:Segmented>

        <controls:SwitchPresenter
            Grid.Row="1"
            Margin="0,10,0,0"
            Value="{Binding SelectedItem.Tag, ElementName=segmentedControl}">
            <controls:Case Value="system">
                <ScrollViewer animations:Implicit.HideAnimations="{StaticResource HideTransitions}" animations:Implicit.ShowAnimations="{StaticResource ShowTransitions}">
                    <TextBlock VerticalAlignment="Center" Text="This is the Download panel" />
                </ScrollViewer>
            </controls:Case>
            <controls:Case Value="download">
                <StackPanel animations:Implicit.HideAnimations="{StaticResource HideTransitions}" animations:Implicit.ShowAnimations="{StaticResource ShowTransitions}">
                    <StackPanel Spacing="5">
                        <controls:SettingsCard
                            Description="设置默认的下载路径地址"
                            Header="默认下载路径"
                            HeaderIcon="{ui:FontIcon Glyph='&#xEB95;'}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBox
                                    Width="400"
                                    IsReadOnly="True"
                                    Text="{x:Bind viewModel.System.DownloadDirPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Command="{x:Bind viewModel.SelectDownloadDirCommand}">
                                    <FontIcon Glyph="&#xEDA2;" ToolTipService.ToolTip="下载默认路径" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>
                    </StackPanel>
                </StackPanel>
            </controls:Case>
        </controls:SwitchPresenter>
    </Grid>
</Page>
