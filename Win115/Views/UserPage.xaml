<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Win115.Views.UserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Win115.Views"
    xmlns:m="using:Win115.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Win115.ViewModels"
    Margin="15,15,15,15"
    d:DataContext="{d:DesignInstance vm:UserViewModel,
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock
            Grid.Row="0"
            Grid.ColumnSpan="2"
            FontSize="18"
            FontWeight="Bold"
            Text="个人信息" />
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            FontWeight="Bold"
            Text="头像：" />
        <Image
            x:Name="img_face"
            Grid.Row="1"
            Grid.Column="1"
            Width="100"
            Height="100"
            HorizontalAlignment="Left"
            Source="{x:Bind viewModel.User.FaceM, Mode=OneWay}" />

        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            FontWeight="Bold"
            Text="用户名：" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="1"
            Text="{x:Bind viewModel.User.UserName, Mode=OneWay}" />

        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            FontWeight="Bold"
            Text="用户Id：" />
        <TextBlock
            Grid.Row="3"
            Grid.Column="1"
            Text="{x:Bind viewModel.User.UserId, Mode=OneWay}" />

        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            FontWeight="Bold"
            Text="会员信息：" />
        <TextBlock Grid.Row="4" Grid.Column="1">
            <Run Text="{x:Bind viewModel.User.VipLevelName, Mode=OneWay}" />
            <Run Text="{x:Bind viewModel.User.ExpiresInText, Mode=OneWay}" />
        </TextBlock>

        <TextBlock
            Grid.Row="5"
            Grid.Column="0"
            FontWeight="Bold"
            Text="总空间：" />
        <TextBlock
            Grid.Row="5"
            Grid.Column="1"
            Text="{x:Bind viewModel.User.AllTotalFormat, Mode=OneWay}" />

        <TextBlock
            Grid.Row="6"
            Grid.Column="0"
            FontWeight="Bold"
            Text="已用空间：" />
        <TextBlock
            Grid.Row="6"
            Grid.Column="1"
            Text="{x:Bind viewModel.User.AllUseFormat, Mode=OneWay}" />

        <TextBlock
            Grid.Row="7"
            Grid.Column="0"
            FontWeight="Bold"
            Text="剩余空间：" />
        <TextBlock
            Grid.Row="7"
            Grid.Column="1"
            Text="{x:Bind viewModel.User.AllRemainFormat, Mode=OneWay}" />
    </Grid>
</Page>
