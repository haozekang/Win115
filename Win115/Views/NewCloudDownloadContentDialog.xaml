<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Win115.Views.NewCloudDownloadContentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Win115.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="1000"
    MaxWidth="9999"
    mc:Ignorable="d">
    <Grid Width="800">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox
            Grid.ColumnSpan="3"
            MinHeight="220"
            Margin="0,0,0,10"
            AcceptsReturn="True"
            PlaceholderText="支持多个链接url，换行符分隔，支持HTTP(S)、FTP、磁力链和电驴链接"
            Text="{x:Bind viewModel.Urls, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="保存路径：" />
        <TextBox
            x:Name="txt_savepath"
            Grid.Row="1"
            Grid.Column="1"
            IsReadOnly="True"
            Text="{x:Bind viewModel.SavePath, Mode=OneWay}" />
        <Button
            x:Name="btn_show_flyout"
            Grid.Row="1"
            Grid.Column="2"
            Margin="5,0,0,0"
            Click="btn_show_flyout_Click"
            Content="浏览" />

        <TextBlock
            Grid.Row="2"
            Grid.ColumnSpan="3"
            Margin="0,5,0,0"
            VerticalAlignment="Center">
            <Run Text="本月配额：" />
            <Run Text="剩" />
            <Run Text="{x:Bind viewModel.Surplus, Mode=OneWay}" />
            <Run Text="/" />
            <Run Text="总" />
            <Run Text="{x:Bind viewModel.Count, Mode=OneWay}" />
        </TextBlock>
    </Grid>
</ContentDialog>
